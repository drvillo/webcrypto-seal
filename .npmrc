# Supply-chain hardening: never run dependency lifecycle scripts on install.
# pnpm 10 already gates build scripts behind pnpm.onlyBuiltDependencies, but this
# also protects contributors/CI that use npm/yarn and blocks pre/post-install hooks.
ignore-scripts=true

# Fail on any lockfile drift when installing in automated environments.
# (CI passes --frozen-lockfile explicitly; this is a belt-and-suspenders default.)
prefer-frozen-lockfile=true

# Refuse to silently downgrade the resolved dependency tree.
resolution-mode=highest
